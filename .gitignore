# ----- Supabase -----
supabase/.branches
supabase/.temp
supabase/.env
# Seeds reales (PII de clientes, cuentas bancarias, etc.) por DEFECTO ignorados.
# Whitelist solo de plantillas y placeholders. Cualquier seed nuevo
# se mantiene fuera del repo a menos que se whitelistee explícitamente.
supabase/seed/*
!supabase/seed/.gitkeep
!supabase/seed/_template.sql
!supabase/seed/README.md

# ----- Variables de entorno -----
.env
.env.*
!.env.example

# ----- Scripts locales con credenciales -----
scripts/run_*.sh
scripts/run_*.ps1
!scripts/run_*.example

# ----- Logs y caches -----
*.log
logs/
coverage/
.coverage
.nyc_output/

# ----- Builds finales -----
*.apk
*.aab
*.exe
*.msix
*.dmg
release-artifacts/
